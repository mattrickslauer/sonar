# Mapbox public token (client-side map rendering)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Live WebSocket stage URL (from the CDK WsApiEndpoint output)
NEXT_PUBLIC_WS_URL=wss://your-ws-api.execute-api.us-east-1.amazonaws.com/live

# --- Server-only AWS config (DynamoDB + S3 media + Bedrock) ---
# Use SONAR_-prefixed names, NOT bare AWS_* — Vercel/Lambda reserve those.
# Unset locally → falls back to the default credential chain (~/.aws).
SONAR_REGION=us-east-1
SONAR_AWS_ACCESS_KEY_ID=
SONAR_AWS_SECRET_ACCESS_KEY=

# DynamoDB table (defaults to "sonar" if unset)
SONAR_TABLE=sonar

# S3 bucket for media blobs (from the CDK MediaBucketName output).
# Unset → media uploads are disabled and /api/media/* returns 503.
SONAR_MEDIA_BUCKET=sonar-media-<account-id>

# --- CloudFront media CDN (optional — reads via signed URLs over private S3) ---
# When all three are set, /api/media/view serves reads from the CloudFront edge
# via short-lived *signed URLs* (same gated, expiring capability as the presigned
# S3 GET). Unset any of them → falls back to presigned S3 (no CDN). Setup:
#   1) openssl genrsa -out cf_private_key.pem 2048
#      openssl rsa -pubout -in cf_private_key.pem -out cf_public_key.pem
#   2) cd infra && npx cdk deploy -c cfPublicKey="$(cat ../cf_public_key.pem)"
#   3) copy the CDK MediaCdnDomain + MediaCdnKeyId outputs below; put the PRIVATE
#      key (contents of cf_private_key.pem) in SONAR_CF_PRIVATE_KEY (Vercel/SSM).
SONAR_CDN_DOMAIN=
SONAR_CF_KEY_PAIR_ID=
SONAR_CF_PRIVATE_KEY=

# --- Amazon Bedrock ("ask the place" AI — Claude Haiku 4.5) ---
# Uses the SAME SONAR_AWS_* IAM identity above (no separate API key). That
# identity needs `bedrock:InvokeModel` on the Haiku inference profile, and
# Bedrock model access must be enabled in the region. Unset creds / access →
# "ask the place" degrades to a deterministic local synthesis (never errors).
# Override the model / inference profile if needed (defaults to the US profile):
# SONAR_BEDROCK_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- Aurora DSQL (durable system-of-record: accounts / user data) ---
# Host from the CDK DsqlEndpoint output. Unset → account/auth features are
# disabled (the app still runs anonymously). Auth uses the same SONAR_AWS_*
# IAM identity above (no DB password) — that identity needs dsql:DbConnect.
SONAR_DSQL_ENDPOINT=<cluster-id>.dsql.us-east-1.on.aws
# Least-privilege Postgres role the app logs in as (see infra/sql/000_app_role.sql).
# Leave as sonar_app; do NOT use "admin" in production.
SONAR_DSQL_USER=sonar_app
SONAR_DSQL_DATABASE=postgres

# --- Transactional email (ZeptoMail SMTP, for OTP sign-in codes) ---
# ZeptoMail "Send Mail" token, used as the SMTP password (username is the
# literal "emailapikey"). Unset → codes are logged to the server console
# instead of emailed (fine for local dev).
SONAR_ZEPTO_TOKEN=
# Verified sender for the agfarms.dev ZeptoMail domain.
SONAR_MAIL_FROM="Sonar <sonar@agfarms.dev>"

# --- Session / auth signing ---
# HS256 secret for session JWTs AND short-lived WebSocket connect tickets.
# Must be >= 32 chars of entropy (e.g. `openssl rand -base64 48`). The SAME
# value must be set in the CDK deploy environment so the WS $connect authorizer
# can verify the tickets the app mints.
SONAR_SESSION_SECRET=

# --- Stripe (per-waypoint subscriptions: $5/mo each permanent waypoint) ---
# Server-only secret key (sk_test_… / sk_live_…). Unset → billing is disabled
# and the "Permanent · $5/mo" drop option is hidden (the app still runs).
STRIPE_SECRET_KEY=sk_test_...
# The recurring per-waypoint Price (price_…), $5/mo. One subscription per account
# whose quantity = number of permanent waypoints; each adds another $5/mo.
STRIPE_PRICE_ID=price_...
# Webhook signing secret (whsec_…). LOCAL dev: from `stripe listen` →
# /api/billing/webhook. PROD: the webhook is the Lambda Function URL, whose
# secret lives in SSM (/sonar/stripe/webhook-secret), not here.
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: absolute base URL for Checkout success/cancel redirects. Unset →
# derived from the request origin (fine for local + preview deploys).
NEXT_PUBLIC_APP_URL=https://mysonar.zone

# --- Anthropic API (bot-tick Lambda captions ONLY) ---
# NOTE: the app's "ask the place" feature runs on Amazon Bedrock (see above) and
# does NOT use this key. This key is only for the bot-tick liveness Lambda.
# The bot-tick Lambda writes festival captions with Claude Haiku. In PROD the
# key lives in SSM (/sonar/anthropic/api-key), read by the Lambda at runtime —
# set it out of band, not here:
#   aws ssm put-parameter --name /sonar/anthropic/api-key --type SecureString \
#     --value sk-ant-... --region "$SONAR_REGION"
# Unset (no SSM param, no env var) → bots fall back to the static caption pool;
# the tick still runs. ANTHROPIC_API_KEY here overrides the SSM lookup (handy
# for running the Lambda outside AWS / local invokes).
ANTHROPIC_API_KEY=sk-ant-...
# Captions are grounded in each drop's location: the bot-tick Lambda reverse-
# geocodes the cell via Mapbox (reuses NEXT_PUBLIC_MAPBOX_TOKEN, plumbed in by
# the CDK stack). Unset → captions still generate, just location-agnostic.
# Bot drops default to a 15-min lifespan; tune with BOT_TTL_SECONDS (Lambda env).
# BOT_TTL_SECONDS=900
