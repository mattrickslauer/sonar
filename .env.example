# Mapbox public token (client-side map rendering)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Live WebSocket stage URL (from the CDK WsApiEndpoint output)
NEXT_PUBLIC_WS_URL=wss://your-ws-api.execute-api.us-east-1.amazonaws.com/live

# --- Server-only AWS config (DynamoDB + S3 media) ---
# Use SONAR_-prefixed names, NOT bare AWS_* — Vercel/Lambda reserve those.
# Unset locally → falls back to the default credential chain (~/.aws).
SONAR_REGION=us-east-1
SONAR_AWS_ACCESS_KEY_ID=
SONAR_AWS_SECRET_ACCESS_KEY=

# DynamoDB table (defaults to "sonar" if unset)
SONAR_TABLE=sonar

# S3 bucket for media blobs (from the CDK MediaBucketName output).
# Unset → media uploads are disabled and /api/media/* returns 503.
SONAR_MEDIA_BUCKET=sonar-media-<account-id>

# --- Aurora DSQL (durable system-of-record: accounts / user data) ---
# Host from the CDK DsqlEndpoint output. Unset → account/auth features are
# disabled (the app still runs anonymously). Auth uses the same SONAR_AWS_*
# IAM identity above (no DB password) — that identity needs dsql:DbConnect.
SONAR_DSQL_ENDPOINT=<cluster-id>.dsql.us-east-1.on.aws
# Least-privilege Postgres role the app logs in as (see infra/sql/000_app_role.sql).
# Leave as sonar_app; do NOT use "admin" in production.
SONAR_DSQL_USER=sonar_app
SONAR_DSQL_DATABASE=postgres

# --- Session / auth signing ---
# HS256 secret for session JWTs AND short-lived WebSocket connect tickets.
# Must be >= 32 chars of entropy (e.g. `openssl rand -base64 48`). The SAME
# value must be set in the CDK deploy environment so the WS $connect authorizer
# can verify the tickets the app mints.
SONAR_SESSION_SECRET=
